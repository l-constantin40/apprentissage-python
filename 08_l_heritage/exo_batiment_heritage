"""
Ce script permet de créer différents bâtiments d'une ville
en évitant de se répéter dans le code grâce au principe d'héritage.
"""

# 1. CRÉATION DES CLASSES

# Classe mère : contient les caractéristiques communes à tous les bâtiments
class Batiment:
    def __init__(self, address, floor):
        self.address = address
        self.floor = floor
        return
    
# Spécialisation : un immeuble possède des balcons en plus
class Immeuble(Batiment):
    def __init__(self, address, floor, number_of_balconies):
        super().__init__(address, floor)
        self.number_of_balconies = number_of_balconies
        return


# Spécialisation : un supermarché possède des rayons en plus
class Supermarkets(Batiment):
    def __init__(self, address, floor, number_of_spokes):
        super().__init__(address, floor)
        self.number_of_spokes = number_of_spokes
        return


# Spécialisation : une banque possède des coffres-forts en plus
class Banque(Batiment):
    def __init__(self, address, floor, number_of_safes):
        super().__init__(address, floor)
        self.number_of_safes = number_of_safes
        return


# 2. CRÉATION DE LA VILLE

